# GenCC-Link configuration. Copy to .env and adjust. All vars are GENCC_LINK_*.
# Nested data config uses a double underscore, e.g. GENCC_LINK_DATA__DB_FILENAME.

# --- Server ---
GENCC_LINK_HOST=127.0.0.1
GENCC_LINK_PORT=8000
GENCC_LINK_TRANSPORT=unified
GENCC_LINK_MCP_PATH=/mcp
# JSON lists. Add the exact public reverse-proxy hostname in production.
GENCC_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
GENCC_LINK_ALLOWED_ORIGINS=[]

# --- Logging ---
GENCC_LINK_LOG_LEVEL=INFO
GENCC_LINK_LOG_FORMAT=console

# --- Data source / local store ---
# Export format: "new" (recommended) or "legacy".
GENCC_LINK_DATA__SOURCE_FORMAT=new
# Directory for the built SQLite database (default: <repo>/data).
# GENCC_LINK_DATA__DATA_DIR=/data
GENCC_LINK_DATA__DB_FILENAME=gencc.sqlite
GENCC_LINK_DATA__DOWNLOAD_TIMEOUT=120
# Build the database on first use by downloading the export if it is absent.
GENCC_LINK_DATA__AUTO_BOOTSTRAP=true
# In-app conditional-refresh scheduler (unified/http transports only). Disable
# when an external scheduler (cron sidecar, k8s CronJob) owns refresh.
GENCC_LINK_DATA__REFRESH_ENABLED=true
GENCC_LINK_DATA__REFRESH_INTERVAL_HOURS=24
GENCC_LINK_DATA__REFRESH_JITTER_SECONDS=300
# Seconds to wait for the cross-process build lock before giving up.
GENCC_LINK_DATA__BUILD_LOCK_TIMEOUT=600
# Query cache (0 disables).
GENCC_LINK_DATA__CACHE_SIZE=512
GENCC_LINK_DATA__CACHE_TTL=3600
